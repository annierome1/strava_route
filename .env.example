# ── AI & Routing ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GRAPHHOPPER_API_KEY=...
MAPBOX_TOKEN=pk.eyJ1...

# OpenRouteService — 10,000 free req/day (strongly recommended over GraphHopper's 500)
# Get key at https://account.heigit.org
ORS_API_KEY=

# ── Strava OAuth ──────────────────────────────────────────────────────────────
# Get credentials at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_ACCESS_TOKEN=

# ── Supabase (backend) ────────────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Copy from: Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Frontend env vars (copy to web/.env.local for dev, set in Vercel for prod) ──
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# URL of the deployed backend (Railway). Leave empty for local dev (Vite proxy handles it).
VITE_API_URL=https://your-app.railway.app

# ── Strava OAuth (app-level — same for all users) ─────────────────────────────
# Create your Strava API app at https://www.strava.com/settings/api
# Set the "Authorization Callback Domain" to your backend domain (Railway URL)
# STRAVA_CLIENT_ID and STRAVA_CLIENT_SECRET stay on the server — never user-specific
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Where Strava redirects after user authorizes (must match your Strava app settings)
STRAVA_REDIRECT_URI=https://your-app.railway.app/strava/callback
# Frontend URL — where the backend redirects the browser after OAuth completes
FRONTEND_URL=https://your-app.vercel.app
